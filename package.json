{
  "name": "hamptons-home-management",
  "version": "1.0.0",
  "description": "Hamptons Home Management Website",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "analyze": "cross-env NODE_ENV=production NODE_OPTIONS=\"--no-deprecation\" next experimental-analyze",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:email": "dotenvx run -- email dev --dir=./src/components/app/email --port=3001",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit --incremental",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_ENV=production NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "3.81.0",
    "@payloadcms/email-nodemailer": "3.81.0",
    "@payloadcms/live-preview-react": "3.81.0",
    "@payloadcms/next": "3.81.0",
    "@payloadcms/payload-cloud": "3.81.0",
    "@payloadcms/richtext-lexical": "3.81.0",
    "@payloadcms/storage-vercel-blob": "3.81.0",
    "@payloadcms/ui": "3.81.0",
    "@react-email/components": "1.0.11",
    "@react-email/font": "0.0.10",
    "@react-email/tailwind": "2.0.7",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cross-env": "10.1.0",
    "date-fns": "4.1.0",
    "focus-trap-react": "12.0.0",
    "libphonenumber-js": "1.12.41",
    "lodash-es": "4.18.1",
    "lucide-react": "1.7.0",
    "next": "16.2.2",
    "next-recaptcha-v3": "1.5.3",
    "payload": "3.81.0",
    "payload-totp": "3.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-use": "17.6.0",
    "server-only": "0.0.1",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.60.1",
    "@eslint/js": "9.39.2",
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "@types/gtag.js": "0.0.20",
    "@types/jsdom": "28.0.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.5.2",
    "@types/nprogress": "0.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-virtualized": "9.22.3",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "react-email": "5.2.10",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide"
    ]
  }
}
